# Required
DISCORD_TOKEN=
OPENROUTER_API_KEY=

# Bot behavior
BOT_PREFIX=bot
BOT_OWNER_IDS=
ALLOWED_GUILD_IDS=
LOG_LEVEL=info

# Storage
DATABASE_PATH=./data/db.sqlite

# Context and replies
MESSAGE_HISTORY_LIMIT=16
REPLY_MAX_CHARACTERS=180
REPLY_CHAIN_LIMIT=6
CHANNEL_CONTEXT_TTL_MS=3600000
TRIGGER_COOLDOWN_MS=5000

# OpenRouter
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=30000
OPENROUTER_MAX_OUTPUT_TOKENS=140
OPENROUTER_TEMPERATURE=0.8

# Random pings
RANDOM_PING_CHANCE=0.04
RANDOM_PING_COOLDOWN_MS=2700000

# Voice notes
VOICE_NOTE_MAX_BYTES=12000000
